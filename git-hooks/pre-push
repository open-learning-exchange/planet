#!/bin/bash

# Pre-push hook: lints the planet app and the gateway before allowing a push.
# Lints the working tree as-is; CI runs the same checks against the pushed
# commits and remains the authoritative gate.

pass=true
RED='\033[1;31m'
GREEN='\033[0;32m'
NC='\033[0m'

repo_root=$(git rev-parse --show-toplevel)

run_lint() {
  local dir=$1
  local label=$2
  local script=$3
  local output

  echo "Running $label lint"
  output=$(cd "$repo_root/$dir" && npm run "$script" 2>&1)
  if [ $? -ne 0 ]; then
    printf "${RED}%s lint failed.${NC}\n" "$label"
    echo "$output"
    pass=false
  else
    printf "${GREEN}%s lint passed.${NC}\n" "$label"
  fi
}

# TODO: switch to lint:all once the sass-lint/htmlhint baseline passes
run_lint "." "planet" "lint"
run_lint "gateway" "gateway" "lint"

if $pass; then
  exit 0
fi

exit 1
